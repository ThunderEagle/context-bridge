<?xml version="1.0" encoding="utf-8"?>
<!--
  Used by the release workflow to produce a dotnet global tool package.
  PackAsTool cannot be used because it does not support platform-specific TFMs
  (net10.0-windows). This nuspec manually constructs the equivalent package structure.

  See scripts/pack-tool.ps1 for the full packaging command.
-->
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>ThunderEagle.ContextBridge</id>
    <version>$version$</version>
    <authors>Scott Williams</authors>
    <description>Zero-dependency MCP memory server for AI coding assistants. Runs as a Windows Service with in-process ONNX embeddings and SQLite vector search.</description>
    <tags>mcp ai memory claude llm embeddings onnx sqlite</tags>
    <copyright>Copyright © 2026 Scott Williams</copyright>
    <projectUrl>https://github.com/ThunderEagle/context-bridge</projectUrl>
    <repository type="git" url="https://github.com/ThunderEagle/context-bridge" />
    <license type="expression">MIT</license>
    <readme>docs/README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <packageTypes>
      <packageType name="DotnetTool" />
    </packageTypes>
  </metadata>
  <files>
    <!-- Tool entry point declaration -->
    <file src="DotnetToolSettings.xml" target="tools/net10.0/any/DotnetToolSettings.xml" />
    <!-- Framework-dependent publish output; produced by: dotnet publish -o publish/tool -->
    <file src="..\..\publish\tool\**\*" target="tools/net10.0/any/" exclude="..\..\publish\tool\**\*.pdb" />
    <!-- README displayed on the NuGet gallery -->
    <file src="..\..\README.md" target="docs/README.md" />
  </files>
</package>
