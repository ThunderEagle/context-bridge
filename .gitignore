# Build outputs
bin/
obj/
out/

# NuGet packages
*.nupkg
*.snupkg
packages/
.nuget/

# Visual Studio / Rider
.vs/
.idea/
*.user
*.suo
*.userprefs
*.sln.docstateprefs
*.DotSettings.user

# Rider / ReSharper
_ReSharper*/
*.resharper

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Test results
TestResults/
coverage/
*.trx
*.coveragexml

# dotnet tool output
publish/

# Models — binary files are downloaded at service install time, not committed
# manifest.json is committed; the binaries are not
models/**/*.onnx
models/**/vocab.txt

# Native extension binaries — downloaded at service install time, not committed
# Place vec0.dll in native/win-x64/ for local dev; obtained from sqlite-vec GitHub releases
native/**/*.dll
native/**/*.dylib
native/**/*.so

# Local dev secrets / config overrides
appsettings.Local.json
appsettings.Development.json
secrets.json

# Data Protection keys (machine-specific, never commit)
DataProtection-Keys/

# SQLite database files (runtime artifacts)
*.db
*.db-shm
*.db-wal

# GitHub Actions local run cache (act)
.act/
REVIEW.md
